# ═══════════════════════════════════════════════════════════════
# Termux proot Debian — Optimized .zshrc
# Optimized for: 3.5GB RAM, aarch64, mobile use
# ═══════════════════════════════════════════════════════════════

# ── Powerlevel10k instant prompt (MUST stay at top) ──────────
if [[ -r "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh" ]]; then
  source "${XDG_CACHE_HOME:-$HOME/.cache}/p10k-instant-prompt-${(%):-%n}.zsh"
fi

# ── PATH (deduplicated) ──────────────────────────────────────
typeset -U PATH
export PATH="$HOME/.bun/bin:$HOME/.nvm/versions/node/v24.13.1/bin:$HOME/.opencode/bin:$HOME/.local/bin:$PATH"

# ── Oh My Zsh ────────────────────────────────────────────────
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME="powerlevel10k/powerlevel10k"
zstyle ':omz:update' mode reminder
DISABLE_UNTRACKED_FILES_DIRTY="true"

plugins=(
  git
  sudo
  copypath
  dirhistory
  history
  colored-man-pages
  zsh-autosuggestions
  fast-syntax-highlighting
)
source $ZSH/oh-my-zsh.sh

# ── Completion performance ───────────────────────────────────
zstyle ':completion:*' use-cache on
zstyle ':completion:*' cache-path ~/.cache/zsh-completion

# ── Editor ───────────────────────────────────────────────────
export EDITOR="hx"
export VISUAL="hx"

# ── Build performance ─────────────────────────────────────────
export MAKEFLAGS="-j4"
export NODE_OPTIONS="--max-old-space-size=512"

# ── NVM (lazy load) ───────────────────────────────────────────
export NVM_DIR="$HOME/.nvm"
nvm() {
    unset -f nvm node npm npx
    [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
    [ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
    nvm "$@"
}
node() { unset -f node; [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"; node "$@"; }
npm()  { unset -f npm;  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"; npm "$@";  }
npx()  { unset -f npx;  [ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"; npx "$@";  }

# ── Bun ───────────────────────────────────────────────────────
export BUN_INSTALL="$HOME/.bun"

# ═══════════════════════════════════════════════════════════════
# ALIASES
# ═══════════════════════════════════════════════════════════════

# ── File Navigation ──────────────────────────────────────────
alias ls="lsd"
alias ll="lsd -la"
alias lt="lsd --tree --depth 2"
alias ..="cd .."
alias ...="cd ../.."

# ── Config Editing ────────────────────────────────────────────
alias zshrc="hx ~/.zshrc"
alias refresh="source ~/.zshrc"

# ── Termux / Debian ───────────────────────────────────────────
alias upgrade="pkg upgrade -y"
alias debian='proot-distro login debian --user root --shared-tmp --termux-home'

# ── Tmux Sessions ─────────────────────────────────────────────
alias dev='tmux has-session -t dev 2>/dev/null && tmux attach-session -t dev || tmux new-session -s dev'
alias dev-stop='tmux kill-session -t dev 2>/dev/null && echo "dev session stopped" || echo "no dev session running"'

# ── Remote Connections ─────────────────────────────────────────
alias pcsession="busybox telnetd -b 127.0.0.1:8023 -F &"
alias macconnect="ssh nikhilsutra@100.69.90.87"

# ── OpenCode ─────────────────────────────────────────────────
alias oc='opencode'
alias opencode-config="hx ~/.config/opencode"

# ── Bun ──────────────────────────────────────────────────────
alias bun="grun $HOME/.bun/bin/bun"
alias bunx="grun $HOME/.bun/bin/bunx"

# ── Safety ──────────────────────────────────────────────────
alias rm='rm -i'
alias cp='cp -i'
alias mv='mv -i'

# ── Utilities ────────────────────────────────────────────────
alias grep='grep --color=auto'
alias h='history'
alias ports='ss -tulanp'
alias mem='free -h'
alias disk='df -h /'

# ── bat (installed as batcat on Debian) ───────────────────────
alias bat='batcat'
alias cat='batcat --paging=never'

# ═══════════════════════════════════════════════════════════════
# OPTIONAL TOOLS
# ═══════════════════════════════════════════════════════════════

# ── FZF ──────────────────────────────────────────────────────
if command -v fzf &>/dev/null; then
  if command -v fdfind &>/dev/null; then
    export FZF_DEFAULT_COMMAND='fdfind --type f --hidden --follow --exclude .git'
    export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
    export FZF_ALT_C_COMMAND='fdfind --type d --hidden --follow --exclude .git'
  fi
  export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border --info=inline'
fi

# ── Zoxide ────────────────────────────────────────────────────
if command -v zoxide &>/dev/null; then
  eval "$(zoxide init zsh)"
fi

# ═══════════════════════════════════════════════════════════════
# SHELL CONFIG
# ═══════════════════════════════════════════════════════════════

# ── Powerlevel10k ────────────────────────────────────────────
[[ ! -f ~/.p10k.zsh ]] || source ~/.p10k.zsh

# ── pipx / uv env ────────────────────────────────────────────
[[ -f "$HOME/.local/bin/env" ]] && . "$HOME/.local/bin/env"

# ── Branded paste ────────────────────────────────────────────
autoload -Uz bracketed-paste-magic
zle -N bracketed-paste bracketed-paste-magic

