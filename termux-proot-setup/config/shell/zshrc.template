# ═══════════════════════════════════════════════════════════════
# GITHUB CODESPACE
# ═══════════════════════════════════════════════════════════════

# Aliases
alias cs-list='gh cs list'
alias cs-logs='gh cs logs -c glorious-space-fiesta-766j5pwrwgr2r66r'

# Help function
cs-help() {
    cat << 'EOF'
GitHub Codespace Helper for Auto Trader Pro

Usage:
  cs              Connect to codespace (interactive shell)
  cs <command>    Run command in codespace
  cs-list         List all codespaces
  cs-logs         View codespace logs
  cs-help         Show this help

Examples:
  cs pytest                           # Run pytest
  cs "git pull origin main"           # Git pull
  cs "ls -la /workspaces/auto_trader_pro"  # List files

Codespace: glorious-space-fiesta-766j5pwrwgr2r66r
EOF
}

# Connect to codespace
cs() {
    if [[ "$1" == "-h" || "$1" == "--help" ]]; then
        cs-help
        return
    fi
    
    if [[ -n "$1" ]]; then
        gh cs ssh -c glorious-space-fiesta-766j5pwrwgr2r66r -- "cd /workspaces/auto_trader_pro && $*"
    else
        gh cs ssh -c glorious-space-fiesta-766j5pwrwgr2r66r
    fi
}

# ═══════════════════════════════════════════════════════════════
# OPENCODE COMPLETIONS
# ═══════════════════════════════════════════════════════════════

###-begin-opencode-completions-###
_opencode_yargs_completions() {
    local cur_word args type_list
    cur_word="${COMP_WORDS[COMP_CWORD]}"
    args=("${COMP_WORDS[@]}")
    mapfile -t type_list < <(opencode --get-yargs-completions "${args[@]}")
    mapfile -t COMPREPLY < <(compgen -W "$( printf '%q ' "${type_list[@]}" )" -- "${cur_word}" |
        awk '/ / { print "\""$0"\"" } /^[^ ]+$/ { print $0 }')
    [ ${#COMPREPLY[@]} -eq 0 ] && COMPREPLY=()
    return 0
}
complete -o bashdefault -o default -F _opencode_yargs_completions opencode
###-end-opencode-completions-###

